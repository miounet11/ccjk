{
  "name": "@ccjk/daemon",
  "type": "module",
  "version": "1.0.0",
  "description": "Background daemon for CCJK remote control",
  "author": "CCJK Team",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "ccjk-daemon": "./bin/daemon.mjs"
  },
  "files": [
    "bin",
    "dist",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "shx rm -rf dist && tsc --noEmit && pkgroll",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@ccjk/wire": "workspace:*",
    "chalk": "catalog:conflicts_chalk_h5_6_2",
    "cross-spawn": "catalog:",
    "fastify": "catalog:",
    "ps-list": "catalog:",
    "socket.io-client": "catalog:conflicts_conflicts_conflicts_socket.io-client_h4_8_1_h4_8_3_h4_8_1"
  },
  "devDependencies": {
    "@types/cross-spawn": "catalog:",
    "@types/node": "catalog:conflicts_conflicts_@types/node_h20_11_5_ge20",
    "pkgroll": "catalog:conflicts_conflicts_pkgroll_h2_26_3_h2_14_2",
    "shx": "catalog:conflicts_conflicts_shx_h0_4_0_h0_3_3",
    "tsx": "catalog:conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_tsx_h4_7_2_h4_20_5_h4_0_0_h4_20_5_h4_20_6_h4_21_0_h4_20_6",
    "typescript": "catalog:conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_typescript_h5_3_3_h5_9_2_h5_h5_9_2_h5_5_9_3_h5_9_3_5_9_3",
    "vitest": "catalog:conflicts_conflicts_vitest_h1_0_0_h3_2_4"
  }
}
