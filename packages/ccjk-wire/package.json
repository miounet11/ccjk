{
  "name": "@ccjk/wire",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared message wire types and Zod schemas for CCJK remote control",
  "author": "CCJK Team",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "README.md",
    "dist",
    "package.json"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "shx rm -rf dist && tsc --noEmit && pkgroll",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "catalog:",
    "tweetnacl": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:conflicts_conflicts_@types/node_h20_11_5_ge20",
    "pkgroll": "catalog:conflicts_conflicts_pkgroll_h2_26_3_h2_14_2",
    "shx": "catalog:conflicts_conflicts_shx_h0_4_0_h0_3_3",
    "typescript": "catalog:conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_conflicts_typescript_h5_3_3_h5_9_2_h5_h5_9_2_h5_5_9_3_h5_9_3_5_9_3",
    "vitest": "catalog:conflicts_conflicts_vitest_h1_0_0_h3_2_4"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
