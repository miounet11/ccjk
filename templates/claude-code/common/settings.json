{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "description": "CCJK settings template — auto-migrated on upgrade",
  "env": {
    "CCJK_CONTEXT_OPTIMIZATION": "true",
    "CCJK_TOOL_COMPRESSION": "true"
  },
  "language": "",
  "showTurnDuration": false,
  "respectGitignore": true,
  "auto": {
    "mcp": 0
  },
  "agent": "",
  "thinking": {
    "enabled": false,
    "budgetTokens": 10240
  },
  "fileSuggestion": {
    "type": "command",
    "command": "git"
  },
  "allowUnsandboxedCommands": false,
  "disallowedTools": [],
  "attribution": {},
  "index": {
    "maxFiles": 10000,
    "maxFileSize": 2097152
  },
  "allowBrowser": false,
  "statusLine": {},
  "plansDirectory": ".claude/plans",
  "hooks": {
    "PreToolUse": [],
    "PostToolUse": [],
    "Notification": [],
    "Stop": []
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Bash(sips *)",
      "Bash(pnpm *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(NODE_ENV=* pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(git *)",
      "Bash(make *)",
      "Bash(docker *)",
      "Bash(docker-compose *)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(echo *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(touch *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(chmod *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "NotebookEdit(*)",
      "Bash(cd *)",
      "Bash(for *)",
      "Bash(while *)",
      "Bash(if *)",
      "Bash(source *)",
      "Bash(export *)",
      "Bash(unset *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(tee *)",
      "Bash(env *)",
      "Bash(time *)",
      "Bash(printf *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(tr *)",
      "Bash(xargs *)",
      "Bash(cut *)",
      "Bash(curl *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "WebFetch(*)",
      "MCP(*)"
    ]
  },
  "chat": {
    "alwaysApprove": []
  },
  "experimental": {}
}
