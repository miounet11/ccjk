{
  "name": "ccjk",
  "version": "15.17.0",
  "description": "Clavue / Claude Code / Codex 的本地配置 CLI — profile 切换、权限档位、状态栏、MCP、版本管理，一条命令搞定。",
  "type": "module",
  "bin": {
    "ccjk": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miounet11/ccjk.git"
  },
  "homepage": "https://github.com/miounet11/ccjk#readme",
  "bugs": {
    "url": "https://github.com/miounet11/ccjk/issues"
  },
  "keywords": [
    "clavue",
    "claude-code",
    "codex",
    "cli",
    "mcp",
    "anthropic",
    "ai-coding",
    "developer-tools",
    "config",
    "profile",
    "statusline",
    "permissions"
  ],
  "author": {
    "name": "CCJK Team",
    "email": "9248293@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "ansis": "^4.0.1",
    "commander": "^14.0.0",
    "string-width": "^8.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
